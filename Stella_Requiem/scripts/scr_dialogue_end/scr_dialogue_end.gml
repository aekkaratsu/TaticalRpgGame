global.end_dia1 = [
    { name: "JeyGrude", msg: "Davin! Help me! The pillar... her hand is still under there!" },
    { name: "Davin", msg: "JeyGrude, stop. Look at the structure... it's about to collapse!" },
    { name: "JeyGrude", msg: "I don't care! I'm not leaving her! Grab that steel bar, we can pry it open!" },
    { name: "Davin", msg: "Kid, listen to me! There's no pulse... she's already gone!" },
    { name: "JeyGrude", msg: "SHUT UP! You don't know that! She's just... she's just unconscious! Help me move it, DAMMIT!" }
];

global.end_dia2 = [
    { name: "Davin", msg: "Look around you! The whole district is coming down! If we stay, we both die right here!" },
    { name: "JeyGrude", msg: "I'm not leaving her behind like scrap metal! I promised her... I promised I'd be home for her birthday!" },
    { name: "Davin", msg: "Jey... look at her face. Look at her eyes. Do you really think she wants you to die with her?" },
    { name: "JeyGrude", msg: "No... no... it wasn't supposed to end like this..." },
    { name: "Davin", msg: "We have to move. NOW. Before we become part of this rubble too!" }
];

global.end_dia3 = [
    { name: "JeyGrude", msg: "..." },
    { name: "JeyGrude", msg: "I'm sorry... I'm so sorry..." },
    { name: "Davin", msg: "Forgive yourself later, kid. For now, just run. Run and don't look back!" },
    { name: "JeyGrude", msg: "(To himself) I'll make them pay for this. Every single one of them..." },
    { name: "JeyGrude", msg: "Let's go, Davin. Let's get out of this hellhole." }
];

global.end_dia4 = [
    { name: "????", msg: "" },
];