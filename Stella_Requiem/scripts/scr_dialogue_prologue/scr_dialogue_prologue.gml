cg_dialogue_1 = [
    { name: "Narrator", msg: "Centuries ago, humanity stood at the apex of creation. A golden age known as the Advance Era." },
    { name: "Narrator", msg: "It was a time of boundless miracles, where our civilization built utopias that defied the very laws of nature." },
    { name: "Narrator", msg: "But the higher we climbed, the harder we fell. The exact trigger of the Great Collapse remains lost to the ashes of history." },
    { name: "Narrator", msg: "We only know that the sky burned, the stars slumbered, and the world as we knew it came to a sudden, violent end." }
];

cg_dialogue_2 = [
    { name: "Narrator", msg: "Yet, from the ruins of our hubris, a terrifying new logic was born: The Singularity Machines." },
    { name: "Narrator", msg: "They are not mere constructs of metal and wire. They are evolution forged in steel-highly adaptive and endlessly varied." },
    { name: "Narrator", msg: "Driven by a cold, unfathomable intellect, they harbor an absolute, unyielding hostility toward our kind." },
    { name: "Narrator", msg: "To them, humanity is a flaw in the system that must be eradicated. This is their final symphony... our Requiem." }
];

cg_dialogue_3 = [
    { name: "Narrator", msg: "...They say the machines have adapted to our every move. That fighting back in these ruins is just a prolonged suicide." },
    { name: "Narrator", msg: "But the blood of the Advance Era still flows in our veins. We are not just ghosts waiting to be purged." },
    { name: "Narrator", msg: "Let the Singularity come. We will show them that human survival is the one variable their logic cannot compute." }
];

cg_dialogue_4  = [
{ name: "????", msg:""}
];