global.town_dia_part1 = [
    { name: "Davin", msg: "Late again, huh? That bag of scrap looks heavier than usual." },
    { name: "JeyGrude", msg: "Found some decent copper wiring near the old ruins. Should fetch a good price." },
    { name: "Davin", msg: "Better cash it in first thing in the morning. You didn't forget what day it is tomorrow, right?" },
    { name: "JeyGrude", msg: "Uh... Tuesday?" },
    { name: "Davin", msg: "Your sister's birthday, you blockhead! She'll have your head if you show up empty-handed." },
    { name: "JeyGrude", msg: "Oh, crap. I completely forgot. I need to find her a gift." },
];

global.town_dia_part2= [
    { name: "Davin", msg: "Haha, you'd better hurry before the shops-- Wait. Do you hear that?" }
]


global.town_dia_part3 = [
    { name: "JeyGrude", msg: "Hear what? The wind?" },
    { name: "Davin", msg: "No, the ground... it's shaking! What the hell is happening?!" },
];

global.town_dia_part4= [
    { name: "Davin", msg: "*Cough*... Kid... are you still breathing?" },
    { name: "JeyGrude", msg: "My... my sister... She's still in the lower district!" },
    { name: "Davin", msg: "Don't look, kid... It's gone. The whole district is just... gone." },
    { name: "JeyGrude", msg: "SHUT UP I WILL go find her" },
    { name: "Davin", msg: "HEY! Wai-"},
    { name: "JeyGrude", msg: "(to him self) Wait for me sis i will go get you!"}
];